<!-- Privacy Policy -->
---
import BaseLayout from '../components/layout/BaseLayout.astro';
import type { Crumb } from '../components/seo/BreadcrumbSchema.astro';

const breadcrumbs: Crumb[] = [{ name: 'Home', url: '/' }, { name: 'Privacy Policy', url: '/privacy/' }];
---
<BaseLayout
  title="Privacy Policy"
  description="AI Tools Review Hub privacy policy — how we collect and handle your data."
  path="/privacy/"
  breadcrumbs={breadcrumbs}
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a><span class="sep">/</span><span>Privacy Policy</span>
  </nav>

  <h1>Privacy Policy</h1>
  <p style="color:var(--c-text-3);margin-top:var(--space-sm)">
    <em>Last updated: June 1, 2026</em>
  </p>

  <div class="post-content" style="margin-top:var(--space-xl)">
    <h2>1. Information We Collect</h2>
    <p><strong>Automatically:</strong> Our web server logs standard information including IP address, browser type, referring pages, and timestamps — as all websites do.</p>
    <p><strong>Voluntarily:</strong> If you email us, we receive your email address and any information you include in your message.</p>

    <h2>2. Cookies</h2>
    <p>This site does not use tracking cookies. We do not run analytics scripts, social media pixels, or advertising trackers. Any cookies set are strictly functional (e.g., load balancers, CDN).</p>

    <h2>3. Affiliate Links</h2>
    <p>Some links are affiliate links. The destination site may set cookies when you click them. These cookies are governed by the destination site's privacy policy.</p>

    <h2>4. Third-Party Services</h2>
    <p>We use: (a) a web hosting provider that may log access data; (b) Cloudflare for CDN and DDoS protection. These providers have their own privacy policies.</p>

    <h2>5. Your Rights (GDPR)</h2>
    <p>You have the right to access, correct, or request deletion of any personal data we may hold. Contact info@saassavvyhub.com.</p>

    <h2>6. Children's Privacy</h2>
    <p>This website is not directed at children under 13.</p>

    <h2>7. Changes</h2>
    <p>We may update this policy. Changes are posted here with an updated date.</p>

    <h2>8. Contact</h2>
    <p>Privacy questions: <strong>info@saassavvyhub.com</strong></p>
  </div>
</BaseLayout>

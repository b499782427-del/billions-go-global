<!-- Base HTML Layout — every page wraps in this -->
---
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import OrganizationSchema from '../seo/OrganizationSchema.astro';
import BreadcrumbSchema from '../seo/BreadcrumbSchema.astro';
import type { Crumb } from '../seo/BreadcrumbSchema.astro';

export interface Props {
  title: string;
  description: string;
  path?: string;
  ogImage?: string;
  ogType?: string;
  datePublished?: string;
  dateModified?: string;
  breadcrumbs?: Crumb[];
}
const {
  title, description,
  path = '/',
  ogImage = '/og-default.png',
  ogType = 'website',
  datePublished,
  dateModified,
  breadcrumbs = [],
} = Astro.props;

const fullTitle = path === '/' ? title : `${title} | AI Tools Review Hub`;
const canonicalUrl = `https://saassavvyhub.com${path}`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Primary SEO -->
  <title>{fullTitle}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonicalUrl}>

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content={ogType}>
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:site_name" content="AI Tools Review Hub">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={fullTitle}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">

  <!-- Performance -->
  <meta http-equiv="X-DNS-Prefetch-Control" content="on">
  <link rel="dns-prefetch" href="//saassavvyhub.com">

  <!-- Styles -->
  <link rel="stylesheet" href="/styles/global.css">
  <style>
    /* Critical above-fold styles for instant render */
    body{font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","Segoe UI",Roboto,sans-serif;color:#e8eaef;background:#0b0d14;line-height:1.7}*{box-sizing:border-box;margin:0;padding:0}a{color:#60a5fa;text-decoration:none}.container{max-width:960px;margin:0 auto;padding:0 1.5rem}.navbar{position:sticky;top:0;z-index:100;background:rgba(11,13,20,.85);backdrop-filter:blur(12px);border-bottom:1px solid #252a36}.navbar-inner{max-width:960px;margin:0 auto;padding:0 1.5rem;display:flex;align-items:center;justify-content:space-between;height:56px}
  </style>

  {datePublished && <meta property="article:published_time" content={datePublished}>}
  {dateModified && <meta property="article:modified_time" content={dateModified}>}

  <!-- Schema (every page gets Organization + Breadcrumb) -->
  <OrganizationSchema />
  {breadcrumbs.length > 0 && <BreadcrumbSchema crumbs={breadcrumbs} />}
</head>
<body>
  <Navbar />
  <main class="container">
    <slot />
  </main>
  <Footer />
</body>
</html>
